{
  "$defs": {
    "ModelProfile": {
      "additionalProperties": false,
      "properties": {
        "api_key_env": {
          "anyOf": [
            {
              "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Api Key Env"
        },
        "auth_mode": {
          "anyOf": [
            {
              "enum": [
                "bearer",
                "x-api-key",
                "both",
                "none"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Auth Mode"
        },
        "base_url": {
          "format": "uri",
          "maxLength": 2083,
          "minLength": 1,
          "title": "Base Url",
          "type": "string"
        },
        "display_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Display Name"
        },
        "endpoint": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Endpoint"
        },
        "extra_headers": {
          "additionalProperties": {
            "type": "string"
          },
          "title": "Extra Headers",
          "type": "object"
        },
        "id": {
          "pattern": "^[a-zA-Z0-9_.-]+$",
          "title": "Id",
          "type": "string"
        },
        "limits": {
          "$ref": "#/$defs/ProviderLimits"
        },
        "model": {
          "title": "Model",
          "type": "string"
        },
        "params": {
          "$ref": "#/$defs/RequestParams"
        },
        "pricing": {
          "anyOf": [
            {
              "$ref": "#/$defs/PricingSpec"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "protocol": {
          "enum": [
            "openai_chat",
            "anthropic_messages"
          ],
          "title": "Protocol",
          "type": "string"
        },
        "verify_tls": {
          "default": true,
          "title": "Verify Tls",
          "type": "boolean"
        }
      },
      "required": [
        "id",
        "protocol",
        "base_url",
        "model"
      ],
      "title": "ModelProfile",
      "type": "object"
    },
    "PricingSpec": {
      "additionalProperties": false,
      "properties": {
        "input_per_million": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Input Per Million"
        },
        "output_per_million": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Output Per Million"
        },
        "reasoning_per_million": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reasoning Per Million"
        }
      },
      "title": "PricingSpec",
      "type": "object"
    },
    "ProviderLimits": {
      "additionalProperties": false,
      "properties": {
        "concurrency": {
          "default": 10,
          "maximum": 10,
          "minimum": 1,
          "title": "Concurrency",
          "type": "integer"
        },
        "qps": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Qps"
        },
        "retries": {
          "default": 3,
          "maximum": 10,
          "minimum": 0,
          "title": "Retries",
          "type": "integer"
        },
        "timeout_seconds": {
          "default": 1800.0,
          "exclusiveMinimum": 0,
          "title": "Timeout Seconds",
          "type": "number"
        }
      },
      "title": "ProviderLimits",
      "type": "object"
    },
    "RequestParams": {
      "additionalProperties": false,
      "properties": {
        "extra_body": {
          "additionalProperties": true,
          "title": "Extra Body",
          "type": "object"
        },
        "json_mode": {
          "default": true,
          "title": "Json Mode",
          "type": "boolean"
        },
        "max_tokens": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Tokens"
        },
        "seed": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Seed"
        },
        "temperature": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Temperature"
        },
        "thinking_budget": {
          "anyOf": [
            {
              "exclusiveMinimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Thinking Budget"
        },
        "thinking_display": {
          "anyOf": [
            {
              "enum": [
                "summarized",
                "omitted"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Thinking Display"
        },
        "thinking_effort": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Thinking Effort"
        },
        "thinking_mode": {
          "anyOf": [
            {
              "enum": [
                "adaptive",
                "enabled",
                "disabled"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Thinking Mode"
        }
      },
      "title": "RequestParams",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "profiles": {
      "items": {
        "$ref": "#/$defs/ModelProfile"
      },
      "title": "Profiles",
      "type": "array"
    },
    "schema_version": {
      "const": 1,
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    }
  },
  "required": [
    "profiles"
  ],
  "title": "ModelsConfig",
  "type": "object"
}
