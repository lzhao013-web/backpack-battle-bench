{
  "$defs": {
    "BoardSpec": {
      "additionalProperties": false,
      "properties": {
        "cells": {
          "anyOf": [
            {
              "items": {
                "maxItems": 2,
                "minItems": 2,
                "prefixItems": [
                  {
                    "type": "integer"
                  },
                  {
                    "type": "integer"
                  }
                ],
                "type": "array"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cells"
        },
        "height": {
          "exclusiveMinimum": 0,
          "title": "Height",
          "type": "integer"
        },
        "width": {
          "exclusiveMinimum": 0,
          "title": "Width",
          "type": "integer"
        }
      },
      "required": [
        "width",
        "height"
      ],
      "title": "BoardSpec",
      "type": "object"
    },
    "InventoryEntrySpec": {
      "additionalProperties": false,
      "properties": {
        "count": {
          "default": 1,
          "exclusiveMinimum": 0,
          "title": "Count",
          "type": "integer"
        },
        "instance_prefix": {
          "anyOf": [
            {
              "pattern": "^[a-z][a-z0-9_]*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Instance Prefix"
        },
        "item_id": {
          "pattern": "^[a-z][a-z0-9_]*$",
          "title": "Item Id",
          "type": "string"
        }
      },
      "required": [
        "item_id"
      ],
      "title": "InventoryEntrySpec",
      "type": "object"
    },
    "ObjectiveSpec": {
      "additionalProperties": false,
      "properties": {
        "config": {
          "additionalProperties": true,
          "title": "Config",
          "type": "object"
        },
        "type": {
          "default": "sum_stat",
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9_.-]*$",
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "config"
      ],
      "title": "ObjectiveSpec",
      "type": "object"
    },
    "ScenarioProvenance": {
      "additionalProperties": false,
      "properties": {
        "candidate_index": {
          "title": "Candidate Index",
          "type": "integer"
        },
        "generator_id": {
          "title": "Generator Id",
          "type": "string"
        },
        "generator_version": {
          "title": "Generator Version",
          "type": "string"
        },
        "seed": {
          "title": "Seed",
          "type": "integer"
        }
      },
      "required": [
        "generator_id",
        "generator_version",
        "seed",
        "candidate_index"
      ],
      "title": "ScenarioProvenance",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Public scenario document referencing definitions from an item catalog.",
  "properties": {
    "board": {
      "$ref": "#/$defs/BoardSpec"
    },
    "difficulty": {
      "default": "medium",
      "enum": [
        "easy",
        "medium",
        "hard"
      ],
      "title": "Difficulty",
      "type": "string"
    },
    "id": {
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9_.-]*$",
      "title": "Id",
      "type": "string"
    },
    "inventory": {
      "items": {
        "$ref": "#/$defs/InventoryEntrySpec"
      },
      "title": "Inventory",
      "type": "array"
    },
    "item_catalog": {
      "minLength": 1,
      "title": "Item Catalog",
      "type": "string"
    },
    "locale": {
      "const": "zh-CN",
      "default": "zh-CN",
      "title": "Locale",
      "type": "string"
    },
    "objective": {
      "$ref": "#/$defs/ObjectiveSpec"
    },
    "provenance": {
      "anyOf": [
        {
          "$ref": "#/$defs/ScenarioProvenance"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "schema_version": {
      "const": 2,
      "default": 2,
      "title": "Schema Version",
      "type": "integer"
    },
    "tags": {
      "items": {
        "type": "string"
      },
      "title": "Tags",
      "type": "array"
    },
    "title": {
      "title": "Title",
      "type": "string"
    },
    "version": {
      "default": "1.0.0",
      "title": "Version",
      "type": "string"
    }
  },
  "required": [
    "id",
    "title",
    "board",
    "item_catalog",
    "inventory",
    "objective"
  ],
  "title": "ScenarioDocumentSpec",
  "type": "object"
}
