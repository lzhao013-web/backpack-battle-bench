{
  "$defs": {
    "SuiteScenarioEntry": {
      "additionalProperties": false,
      "properties": {
        "oracle": {
          "title": "Oracle",
          "type": "string"
        },
        "oracle_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Oracle Hash",
          "type": "string"
        },
        "scenario": {
          "title": "Scenario",
          "type": "string"
        },
        "scenario_hash": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Scenario Hash",
          "type": "string"
        },
        "weight": {
          "default": 1.0,
          "exclusiveMinimum": 0,
          "title": "Weight",
          "type": "number"
        }
      },
      "required": [
        "scenario",
        "oracle",
        "scenario_hash",
        "oracle_hash"
      ],
      "title": "SuiteScenarioEntry",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "allowed_plugins": {
      "items": {
        "type": "string"
      },
      "title": "Allowed Plugins",
      "type": "array"
    },
    "id": {
      "pattern": "^[a-z][a-z0-9_.-]*$",
      "title": "Id",
      "type": "string"
    },
    "item_catalog": {
      "title": "Item Catalog",
      "type": "string"
    },
    "item_catalog_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Item Catalog Hash",
      "type": "string"
    },
    "locale": {
      "const": "zh-CN",
      "default": "zh-CN",
      "title": "Locale",
      "type": "string"
    },
    "scenarios": {
      "items": {
        "$ref": "#/$defs/SuiteScenarioEntry"
      },
      "title": "Scenarios",
      "type": "array"
    },
    "schema_version": {
      "const": 2,
      "default": 2,
      "title": "Schema Version",
      "type": "integer"
    },
    "title": {
      "title": "Title",
      "type": "string"
    },
    "version": {
      "title": "Version",
      "type": "string"
    },
    "visual_pack": {
      "title": "Visual Pack",
      "type": "string"
    },
    "visual_pack_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Visual Pack Hash",
      "type": "string"
    }
  },
  "required": [
    "id",
    "version",
    "title",
    "item_catalog",
    "item_catalog_hash",
    "visual_pack",
    "visual_pack_hash",
    "allowed_plugins",
    "scenarios"
  ],
  "title": "SuiteSpec",
  "type": "object"
}
