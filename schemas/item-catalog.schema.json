{
  "$defs": {
    "EffectSpec": {
      "additionalProperties": false,
      "properties": {
        "config": {
          "additionalProperties": true,
          "title": "Config",
          "type": "object"
        },
        "type": {
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9_.-]*$",
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "type"
      ],
      "title": "EffectSpec",
      "type": "object"
    },
    "ItemDefinitionSpec": {
      "additionalProperties": false,
      "properties": {
        "category": {
          "default": "support",
          "minLength": 1,
          "title": "Category",
          "type": "string"
        },
        "display_name": {
          "minLength": 1,
          "title": "Display Name",
          "type": "string"
        },
        "effects": {
          "items": {
            "$ref": "#/$defs/EffectSpec"
          },
          "title": "Effects",
          "type": "array"
        },
        "id": {
          "minLength": 1,
          "pattern": "^[a-z][a-z0-9_]*$",
          "title": "Id",
          "type": "string"
        },
        "rotations": {
          "items": {
            "enum": [
              0,
              90,
              180,
              270
            ],
            "type": "integer"
          },
          "title": "Rotations",
          "type": "array"
        },
        "shape": {
          "items": {
            "maxItems": 2,
            "minItems": 2,
            "prefixItems": [
              {
                "type": "integer"
              },
              {
                "type": "integer"
              }
            ],
            "type": "array"
          },
          "title": "Shape",
          "type": "array"
        },
        "stats": {
          "additionalProperties": {
            "type": "integer"
          },
          "title": "Stats",
          "type": "object"
        }
      },
      "required": [
        "id",
        "display_name",
        "shape"
      ],
      "title": "ItemDefinitionSpec",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "id": {
      "pattern": "^[a-z][a-z0-9_.-]*$",
      "title": "Id",
      "type": "string"
    },
    "items": {
      "items": {
        "$ref": "#/$defs/ItemDefinitionSpec"
      },
      "title": "Items",
      "type": "array"
    },
    "schema_version": {
      "const": 1,
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "version": {
      "title": "Version",
      "type": "string"
    }
  },
  "required": [
    "id",
    "version",
    "items"
  ],
  "title": "ItemCatalogSpec",
  "type": "object"
}
